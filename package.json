{
  "name": "nexus-campus-event-platform",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "turbo run build",
    "vercel-build": "pnpm --filter @nexus/web run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "format": "turbo run format",
    "fyp:docx": "python scripts/build_fyp_docx.py"
  },
  "devDependencies": {
    "@mohtasham/md-to-docx": "^2.18.0",
    "turbo": "^2.0.0",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20",
    "pnpm": "10.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@prisma/client", "@prisma/engines", "prisma", "esbuild", "sharp"],
    "overrides": {
      "ioredis": "5.11.1"
    }
  }
}
