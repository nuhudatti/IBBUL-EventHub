# ─── IBBUL Email (SMTP) ───────────────────────────────────────────────
# Set MAIL_ENABLED=true and fill SMTP_* for real inbox delivery.
MAIL_ENABLED="true"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER="your-university-email@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="IBBUL Event Platform <your-university-email@gmail.com>"
SMTP_REPLY_TO="events@ibbul.edu.ng"

S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
